{
    "name": "@klasp/server",
    "version": "0.0.0",
    "description": "Server implementation for Klasp Realtime APIs.",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "lint": "biome check ."
    },
    "dependencies": {
        "@klasp/core": "workspace:*"
    },
    "devDependencies": {
        "zod": "^4.0.0"
    },
    "peerDependencies": {
        "zod": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "zod": {
            "optional": true
        }
    }
}
