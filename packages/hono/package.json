{
    "name": "@klasp/hono",
    "version": "0.0.0",
    "description": "Hono adapter for Klasp.",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "lint": "biome check ."
    },
    "dependencies": {
        "@klasp/core": "workspace:*",
        "@klasp/server": "workspace:*"
    },
    "peerDependencies": {
        "hono": "^4.0.0"
    }
}
