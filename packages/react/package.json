{
    "name": "@klasp/react",
    "version": "0.0.0",
    "description": "React bindings for Klasp.",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "biome check ."
    },
    "dependencies": {
        "@klasp/client": "workspace:*",
        "@klasp/core": "workspace:*"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.2.14"
    }
}
